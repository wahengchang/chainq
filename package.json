{
  "name": "chain-cli",
  "version": "0.0.0",
  "type": "module",
  "description": "Run multi-step prompt chains on local CLI models, defined in one YAML file.",
  "bin": {
    "chain": "./src/cli/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "viz": "tsx scripts/e2e-trace.ts",
    "e2e": "vitest run --config vitest.e2e.config.ts",
    "e2e:cli": "vitest run --config vitest.e2e.config.ts",
    "e2e:demo": "tsx e2eCli/demo.ts",
    "e2e:ui": "playwright test --ui",
    "e2e:ui:headless": "playwright test",
    "e2e:ui:headed": "playwright test --headed",
    "e2e:ui:demo": "SLOWMO=${SLOWMO:-900} playwright test --headed -g replays",
    "e2e:ui:debug": "playwright test --debug -g replays"
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
